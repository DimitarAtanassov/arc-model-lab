# Copy to `.env` and adjust as needed: `cp .env.example .env`
#
# Two consumers read this file: the app loads ARC_ and ARC_EVAL_ variables via
# pydantic-settings; docker compose reads POSTGRES_* and ARC_API_PORT. Keep real
# secrets in a secret store, never in a committed .env.

# --- Postgres (consumed by docker compose) ---
POSTGRES_USER=arc
POSTGRES_PASSWORD=arc
POSTGRES_DB=arc_model_lab
POSTGRES_PORT=5432

# --- Database (app, prefix: ARC_) ---
ARC_DATABASE_URL=postgresql+psycopg://arc:arc@localhost:5432/arc_model_lab
# Echo SQL to logs; noisy, enable only when debugging queries.
ARC_DB_ECHO=false

# --- Model loading ---
# Default model resolved from the catalog (seeds/models.local.json) by name.
# Provider, model id, tokenizer, and adapter live in the catalog, not here.
ARC_MODEL_NAME=qwen2.5-1.5b-instruct
# HuggingFace weight cache directory. Unset uses the HF default (HF_HOME).
# ARC_MODEL_CACHE_DIR=/var/cache/huggingface

# --- Compute device ---
# auto prefers CUDA, then MPS, then CPU. Pin to cpu for models that exceed the
# Apple MPS 4 GiB per-tensor limit (which aborts the process). One of: auto, cpu, mps, cuda.
ARC_DEVICE=cpu

# --- Generation ---
ARC_MAX_INPUT_TOKENS=1024
ARC_MAX_OUTPUT_TOKENS=256
# Sampling temperature: 0.0 = greedy/deterministic, higher = more random (max 2.0).
ARC_TEMPERATURE=0.0

# --- HTTP server ---
# ARC_API_PORT is the app's bind port and the port docker compose publishes; keep
# ARC_API_HOST at 0.0.0.0 for Docker so the published port reaches the container.
ARC_API_HOST=0.0.0.0
ARC_API_PORT=8000

# --- Evaluation (arc-eval integration, prefix: ARC_EVAL_) ---
# Base URL of the arc-eval service. An experiment run scores its output against
# the metrics the run names; an empty value disables the call so the run's
# evaluation.status is "skipped" (no error). /inference never evaluates.
ARC_EVAL_SERVICE_URL=
ARC_EVAL_TIMEOUT_SECONDS=30
# Max concurrent arc-eval calls during a batch fan-out (replay/backfill).
ARC_EVAL_CONCURRENCY=8
