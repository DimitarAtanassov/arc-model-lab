# Copy to `.env` and adjust as needed: `cp .env.example .env`

# --- Postgres (consumed by docker compose) ---
POSTGRES_USER=arc
POSTGRES_PASSWORD=arc
POSTGRES_DB=arc_model_lab
POSTGRES_PORT=5432

# --- Application (prefix: ARC_) ---
ARC_DATABASE_URL=postgresql+psycopg://arc:arc@localhost:5432/arc_model_lab
ARC_DB_ECHO=false

# Model registration + loading
ARC_MODEL_NAME=qwen2.5-1.5b-instruct
ARC_MODEL_PROVIDER=huggingface
ARC_MODEL_ID=Qwen/Qwen2.5-1.5B-Instruct
ARC_TOKENIZER_ID=Qwen/Qwen2.5-1.5B-Instruct
# ARC_ADAPTER_PATH=

# Generation
ARC_MAX_INPUT_TOKENS=1024
ARC_MAX_NEW_TOKENS=256
# Deterministic decoding: 1 = greedy (fast), >1 = beam search (slower, higher quality).
ARC_NUM_BEAMS=1

# HTTP server
ARC_API_HOST=0.0.0.0
ARC_API_PORT=8000

# --- Evaluation (arc-eval integration, prefix: ARC_EVAL_) ---
# Base URL of the arc-eval service. Empty disables evaluation:
# /summarize with "evaluate": true then returns evaluation.status = "skipped".
ARC_EVAL_SERVICE_URL=
ARC_EVAL_TIMEOUT_SECONDS=30
