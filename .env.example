# Copy to `.env` and adjust as needed: `cp .env.example .env`

# --- Postgres (consumed by docker compose) ---
POSTGRES_USER=arc
POSTGRES_PASSWORD=arc
POSTGRES_DB=arc_model_lab
POSTGRES_PORT=5432

# --- Application (prefix: ARC_) ---
ARC_DATABASE_URL=postgresql+psycopg://arc:arc@localhost:5432/arc_model_lab
ARC_DB_ECHO=false

# Model registration + loading
ARC_MODEL_NAME=qwen2.5-1.5b-instruct
ARC_MODEL_PROVIDER=huggingface
ARC_MODEL_ID=Qwen/Qwen2.5-1.5B-Instruct
ARC_TOKENIZER_ID=Qwen/Qwen2.5-1.5B-Instruct
# ARC_ADAPTER_PATH=

# Generation
ARC_MAX_INPUT_TOKENS=1024
ARC_MAX_OUTPUT_TOKENS=256
# Sampling temperature: 0.0 = greedy/deterministic, higher = more random (max 2.0).
ARC_TEMPERATURE=0.0

# HTTP server. ARC_API_PORT is the app's bind port and the port docker compose
# publishes; keep ARC_API_HOST at 0.0.0.0 for Docker so the published port reaches
# the container.
ARC_API_HOST=0.0.0.0
ARC_API_PORT=8000

# --- Evaluation (arc-eval integration, prefix: ARC_EVAL_) ---
# Base URL of the arc-eval service. An experiment run scores its output against
# the metrics the run names; an empty value disables the call so the run's
# evaluation.status is "skipped" (no error). /inference never evaluates.
ARC_EVAL_SERVICE_URL=
ARC_EVAL_TIMEOUT_SECONDS=30
